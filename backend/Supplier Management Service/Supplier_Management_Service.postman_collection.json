              "host": ["{{base_url}}"],
              "path": ["api", "v1", "purchase-orders"],
              "query": [
                {
                  "key": "status",
                  "value": "DRAFT",
                  "disabled": true,
                  "description": "Optional status filter (e.g. DRAFT, SUBMITTED, APPROVED)"
                },
                {
                  "key": "supplierId",
                  "value": "3fa85f64-5717-4562-b3fc-2c963f66afa6",
                  "disabled": true,
                  "description": "Optional supplier ID filter"
                }
              ]
            },
            "description": "Get all purchase orders with optional filters"
