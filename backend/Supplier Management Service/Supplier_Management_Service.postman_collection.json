  "item": [
    {
      "name": "Purchase Orders",
      "description": "Purchase order management and integration endpoints",
      "item": [
        {
          "name": "Create Purchase Order",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"supplierId\": \"3fa85f64-5717-4562-b3fc-2c963f66afa6\",\n  \"expectedDeliveryDate\": \"2023-12-01T00:00:00Z\",\n  \"items\": [\n    {\n      \"productId\": \"3fa85f64-5717-4562-b3fc-2c963f66afa6\",\n      \"quantity\": 10,\n      \"unitPrice\": 100.0\n    }\n  ]\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/v1/purchase-orders",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "purchase-orders"]
            },
            "description": "Create a new purchase order in DRAFT status"
          }
        },
        {
          "name": "Get Purchase Order by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/purchase-orders/:id",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "purchase-orders", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "3fa85f64-5717-4562-b3fc-2c963f66afa6",
                  "description": "Purchase Order UUID"
                }
              ]
            },
            "description": "Get purchase order by ID"
          }
        },
        {
          "name": "Get All Purchase Orders",
          "request": {
            "method": "GET",
            "header": [],
